{
  "include": [
    "flows",
    "tools"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    ".venv",
    "**/out_long",
    "**/out_short"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "strict",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "pythonVersion": "3.11",
  "pythonPlatform": "Windows",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "."
      ]
    }
  ]
}
